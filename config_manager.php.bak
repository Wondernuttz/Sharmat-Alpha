        .settings-checkbox-group input[type="checkbox"]:checked {
            background: #FDF5D0;
            border-color: #FDF5D0;
        }

        .settings-checkbox-group input[type="checkbox"]:checked::after {
            content: '✓';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #3D2A5C;
            font-size: 14px;
            font-weight: bold;
        }

        .settings-checkbox-group input[type="checkbox"]:hover {
