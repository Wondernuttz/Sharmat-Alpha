            $npcName = $_GET['npc'] ?? '';
            $acts = isset($_GET['acts']) ? json_decode($_GET['acts'], true) : [];
            $bookingType = $_GET['booking_type'] ?? 'per_act';
            $addons = isset($_GET['addons']) ? json_decode($_GET['addons'], true) : [];
            $groupSize = intval($_GET['group_size'] ?? 1);

            if (empty($npcName)) {
